# ================================================================
# TELEGRAM FILE SHARE BOT — Environment Variables
# Railway pe inhe Variables tab mein set karo
# ================================================================

# ─── REQUIRED ───────────────────────────────────────────────────
# Telegram Bot Token (@BotFather se milega)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Bot username (without @)
BOT_USERNAME=your_bot_username

# Admin Telegram User IDs (comma separated)
ADMIN_IDS=123456789,987654321

# MongoDB Connection URI (MongoDB Atlas free tier works)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Private Telegram Channel ID where files will be stored
# 1. Create a private channel
# 2. Add your bot as admin with "Post Messages" permission  
# 3. Forward any message to @userinfobot to get channel ID
# ID always starts with -100
STORAGE_CHANNEL_ID=-1001234567890

# ─── FORCE JOIN ─────────────────────────────────────────────────
# Channels users must join before using bot
# Format: @channel1,@channel2 OR -100xxx,-100yyy
FORCE_JOIN_CHANNELS=@yourchannel
FORCE_JOIN_ENABLED=true

# ─── OPTIONAL ───────────────────────────────────────────────────

# Bot display name
BOT_NAME=FileVault Bot

# Support username (without @)
SUPPORT_USERNAME=your_support_username

# MongoDB database name
DB_NAME=tg_filebot

# Max file size in MB (Telegram limit: 2000 MB for bots)
MAX_FILE_SIZE_MB=2000

# Max files per user
MAX_FILES_PER_USER=1000

# Free storage per user in MB
FREE_STORAGE_MB=5000

# Rate limiting
RATE_LIMIT_UPLOADS_PER_MIN=10
RATE_LIMIT_DOWNLOADS_PER_MIN=20

# Encryption key for secure links (any random 32+ char string)
ENCRYPTION_KEY=your-super-secret-32-char-key-here-change-this

# Webhook URL for Railway (Railway automatically sets PORT)
# Format: https://your-app.railway.app
# Leave empty for polling mode (good for testing)
WEBHOOK_URL=

# Auto delete bot messages after N seconds (0 = disabled)
AUTO_DELETE_SECONDS=0

# Maintenance mode
MAINTENANCE_MODE=false

# Debug logging
DEBUG=false
